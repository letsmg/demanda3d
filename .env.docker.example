# =============================================
# Docker Environment Variables — Demanda3D
# =============================================
# Copie este arquivo para .env.docker e preencha com valores reais.
# O arquivo .env.docker NUNCA deve ser versionado (já está no .gitignore).

# PostgreSQL Master
POSTGRES_DB=demanda_db
POSTGRES_USER=demanda_user
POSTGRES_PASSWORD=change-me-master-password

# PostgreSQL Replica
REPL_USER=demanda_user
REPL_PASSWORD=change-me-replica-password
REPL_SLOT=demanda3d_replica_slot
REPL_APP_NAME=demanda3d_replica
MASTER_HOST=postgres-demanda3d
MASTER_PORT=5432