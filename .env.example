APP_NAME="Demanda 3D"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Stripe Test Keys — substituir pelos seus
PAYMENT_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
PAYMENT_SECRET_KEY=sk_test_xxxxxxxxxxxx
PAYMENT_RESTRICTED_KEY=rk_test_xxxxxxxxxxxx

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# Argon2id Configuration
ARGON2ID_MEMORY=65536
ARGON2ID_TIME=3
ARGON2ID_THREADS=2
PASSWORD_STRETCHING=false

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql

# PostgreSQL Master (escrita) — porta exposta no docker-compose
# Dev:    5432 (docker-compose.yml)
# Prod:   5436 (docker-compose-prod.yml, container demanda-psql-prod)
# Hom:    5438 (docker-compose-hom.yml, container demanda-psql-hom)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=demanda3d
DB_USERNAME=postgres
DB_PASSWORD=postgres

# PostgreSQL Replica (leitura) — porta exposta no docker-compose
# Dev:    não configurado (opcional em dev local)
# Prod:   5437 (docker-compose-prod.yml, container demanda-psql-rep-prod)
# Hom:    não configurado (HOM não tem réplica atualmente)
#
# IMPORTANTE: Se estas variáveis NÃO forem definidas, o config/database.php
# usa os valores do master como fallback. Todas as queries (read e write)
# vão para o master — a réplica só é usada se DB_REPLICA_HOST estiver definido.
DB_REPLICA_HOST=127.0.0.1
DB_REPLICA_PORT=5437
DB_REPLICA_DATABASE=demanda3d
DB_REPLICA_USERNAME=postgres
DB_REPLICA_PASSWORD=postgres

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Sentry DSN — preencher com o DSN do projeto no Sentry.io
SENTRY_LARAVEL_DSN=

VITE_APP_NAME="${APP_NAME}"

# Google Cloud Vision API
GOOGLE_CLOUD_KEY_FILE="${PWD}/gcloud-api-example.json"

# PostgreSQL Read/Write Splitting
# true  → HA com réplica (master + hot standby para leitura)
# false → conexões read/write apontam para o mesmo host
DB_READ_WRITE_SPLIT=true

# OpenSearch (busca otimizada — somente local)
# Em produção na Oracle Free Tier, manter OPENSEARCH_ENABLED=false
# para que as buscas usam PostgreSQL nativamente, sem depender do container.
OPENSEARCH_ENABLED=true
OPENSEARCH_HOST=127.0.0.1
OPENSEARCH_PORT=9201
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD="Demanda3D@OS2026!"
OPENSEARCH_SSL_VERIFY=false

# Grafana + Loki + Promtail (métricas e alertas — somente local)
# Em produção, GRAFANA_ENABLED=false (container não sobe).
GRAFANA_ENABLED=true
